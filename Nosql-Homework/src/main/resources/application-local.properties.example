# Copy this file to application-local.properties and fill in local secrets.
# application-local.properties is ignored by git.

# MongoDB
# If the user is created in admin, keep authSource=admin.
# If the user is created in nosql_homework, change authSource=nosql_homework.
spring.data.mongodb.uri=mongodb://mongo:123456@localhost:27017/nosql_homework?authSource=admin

# LLM config for DeepSeek's OpenAI-compatible API.
# Do not include a "Bearer " prefix in the key.
langchain4j.openai.api-key=
langchain4j.openai.base-url=https://api.deepseek.com
langchain4j.openai.model-name=deepseek-v4-flash

# Embedding API Key for Aliyun DashScope / Bailian.
tiger.rag.embedding.api-key=

# GitHub Token, separate multiple tokens with commas.
github.tokens=
